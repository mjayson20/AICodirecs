# Copy this file to .env and adjust values

# Path to fine-tuned model checkpoint, or Hugging Face model ID
MODEL_PATH=Salesforce/codet5p-770m-py

# Inference settings
MAX_INPUT_TOKENS=256
MAX_NEW_TOKENS=64
NUM_BEAMS=2
TEMPERATURE=0.2
DO_SAMPLE=false

# Cache (LRU entries)
CACHE_SIZE=256

# Server
HOST=127.0.0.1
PORT=8000
